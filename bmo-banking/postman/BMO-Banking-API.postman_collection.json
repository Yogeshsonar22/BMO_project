{
  "info": {
    "name": "BMO Banking API",
    "description": "BMO Banking Microservices - Complete API Collection",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url",  "value": "http://localhost:8080" },
    { "key": "token",     "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/api/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"John\",\n  \"lastName\": \"Doe\",\n  \"email\": \"john.doe@bmo.com\",\n  \"password\": \"password123\",\n  \"phone\": \"+1-416-555-0100\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.data && json.data.token) {",
                  "  pm.collectionVariables.set('token', json.data.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/api/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john.doe@bmo.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Accounts",
      "item": [
        {
          "name": "Create Account",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/api/accounts",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": 1,\n  \"accountType\": \"CHEQUING\",\n  \"currency\": \"CAD\",\n  \"initialDeposit\": 5000.00\n}"
            }
          }
        },
        {
          "name": "Get Account by ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/api/accounts/1"
          }
        },
        {
          "name": "Get Balance",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/api/accounts/BMO1234567890/balance"
          }
        },
        {
          "name": "Get All Accounts for User",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/api/accounts/user/1"
          }
        }
      ]
    },
    {
      "name": "Transactions",
      "item": [
        {
          "name": "Internal Transfer",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/api/transactions/transfer",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fromAccountNumber\": \"BMO1234567890\",\n  \"toAccountNumber\":   \"BMO0987654321\",\n  \"amount\": 250.00,\n  \"description\": \"Rent payment\"\n}"
            }
          }
        },
        {
          "name": "Get Transaction by ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/api/transactions/1"
          }
        },
        {
          "name": "Get Transaction by Reference",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/api/transactions/ref/TXN-ABCD1234"
          }
        },
        {
          "name": "Get Account Transaction History",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/api/transactions/account/BMO1234567890"
          }
        }
      ]
    },
    {
      "name": "Payments",
      "item": [
        {
          "name": "UPI Payment",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/api/payments/upi",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fromAccountNumber\": \"BMO1234567890\",\n  \"upiId\": \"jane.doe@td\",\n  \"amount\": 100.00,\n  \"description\": \"Split dinner\"\n}"
            }
          }
        },
        {
          "name": "Bill Payment",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/api/payments/bill",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fromAccountNumber\": \"BMO1234567890\",\n  \"billerName\": \"Rogers Telecom\",\n  \"billNumber\": \"INV-2023-10-001\",\n  \"amount\": 89.99,\n  \"description\": \"Monthly phone bill\"\n}"
            }
          }
        },
        {
          "name": "Get Payment by ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/api/payments/1"
          }
        },
        {
          "name": "Get Payment by Reference",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/api/payments/ref/UPI-ABC12345"
          }
        },
        {
          "name": "Get Account Payment History",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/api/payments/account/BMO1234567890"
          }
        }
      ]
    }
  ]
}
